{
  "name": "bandra-smile-studio",
  "version": "1.0.0",
  "description": "Premium dental clinic website — Bandra West, Mumbai",
  "scripts": {
    "dev": "npx tailwindcss -c config/tailwind.config.js -i src/css/main.css -o src/css/output.css --watch",
    "build": "npx tailwindcss -c config/tailwind.config.js -i src/css/main.css -o src/css/output.css --minify",
    "start": "npx serve . -l 3000"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  }
}
